generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  imageUrl    String
  images      String   @default("[]")
  isFeatured  Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hookTitle     String?
  hookSubtitle  String?
  hookDesc      String?
  hadithText    String?
  reviewImages1 String? // للحفظ كـ JSON String
  reviewImages2 String? // للحفظ كـ JSON String
  packagesData String? 

  @@map("product")
}

model Order {
  id              String   @id @default(uuid())
  customerName    String
  customerPhone   String
  customerAddress String
  totalPrice      Float
  status          String   @default("pending")
  isPaid          Boolean  @default(false)
  orderItems      String   
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("order")
}
